.env
.env.*
!.env.example
__pycache__/
*.pyc

# Build artifacts / dependencies / local-only docs
node_modules/
*.tsbuildinfo
MEMORY.md

# Local-only state, scratch files, secrets
.claude/
.logs/
*.timestamp-*.mjs

# SSH deploy keys — NEVER commit. The droplet has its own copy in /root/.
deploy_key
deploy_key.pub
*.pem
id_rsa
id_rsa.pub

# Allow front-end production builds for the static-host deploy.
# main-website/dist/ + waitlist-page/dist/ + admin-dashboard/dist/ +
# b2b-dashboard/dist/ are committed so the droplet's git-reset deploy
# ships compiled assets without needing Node on the server. Only the
# python service dir and the native consumer app build are ignored.
app/dist/
consumer-app/dist/