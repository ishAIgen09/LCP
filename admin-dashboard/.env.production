# Production builds emit same-origin /api/* paths so Nginx on
# hq.localcoffeeperks.com can reverse-proxy /api/* to the FastAPI
# backend on :8000. Vite reads .env.production with higher priority than
# .env.local during `npm run build`, so this overrides any per-machine
# droplet-IP overrides developers keep around for local dev.
VITE_API_BASE_URL=
