DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/indie_coffee_loop

# Business App login gateway — JWT signing key. Rotate before any non-local use.
# Per-row credentials live in brands.password_hash and cafes.pin_hash.
JWT_SECRET=dev-secret-change-me
JWT_TTL_HOURS=12

# Where the Business App (Vite) is served from. Used to build Stripe
# Checkout success / cancel redirect URLs.
FRONTEND_BASE_URL=http://localhost:5173

# Comma-separated list of origins the API will accept from the browser.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5276,http://127.0.0.1:5276

# Stripe — use test keys (sk_test_… / pk_test_…) locally.
STRIPE_SECRET_KEY=sk_test_xxx
# Publishable key — surfaced to the client when we ever embed Stripe
# Elements directly. Optional today; safe to commit publishable values
# (they're public by design) but keep them in env for parity.
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Recurring subscription Price IDs created in the Stripe Dashboard. The
# /api/billing/checkout endpoint reads these to build the line item; if
# either is unset, the backend falls back to inline price_data with the
# matching pence/month so local dev still works without provisioning
# Stripe products. Tier slugs match the b2b dashboard's PlanCard ids.
STRIPE_PRIVATE_PRICE_ID=
STRIPE_GLOBAL_PRICE_ID=
# Signing secret for /api/billing/webhook. Get one of:
#   a) Run `stripe listen --forward-to http://localhost:8000/api/billing/webhook`
#      and paste the whsec_… it prints here. This is the recommended local path.
#   b) Skip verification in dev by setting DEBUG_SKIP_STRIPE_SIG=true (below).
#      Do NOT do this in any deployed environment.
STRIPE_WEBHOOK_SECRET=
DEBUG_SKIP_STRIPE_SIG=false
